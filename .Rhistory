library(nnet)
library(caret)
library(dplyr)
library(ggplot2)
library(neuralnet)
library(e1071)
library(class)
library(rpart)
library(randomForest)
resultados_clasificacion <- data.frame()
agregar_resultado <- function(nombre, acc, tiempo) {
data.frame(
Modelo = nombre,
Accuracy = round(acc, 4),
Tiempo_seg = round(tiempo["elapsed"], 3)
)
}
tiempo_nb <- system.time({
modelo_nb <- naiveBayes(price_category ~ ., data = train_data)
pred_nb <- predict(modelo_nb, test_data)
})
acc_nb <- confusionMatrix(pred_nb, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Naive Bayes", acc_nb, tiempo_nb)
)
tiempo_lr <- system.time({
modelo_lr <- multinom(price_category ~ ., data = train_data, trace = FALSE)
pred_lr <- predict(modelo_lr, test_data)
})
acc_lr <- confusionMatrix(pred_lr, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Regresión Logística", acc_lr, tiempo_lr)
)
tiempo_knn <- system.time({
pred_knn <- knn(
train = train_scaled,
test = test_scaled,
cl = train_data$price_category,
k = 15
)
})
resultados_clasificacion <- data.frame()
agregar_resultado <- function(nombre, acc, tiempo) {
data.frame(
Modelo = nombre,
Accuracy = round(acc, 4),
Tiempo_seg = round(tiempo["elapsed"], 3)
)
}
tiempo_nb <- system.time({
modelo_nb <- naiveBayes(price_category ~ ., data = train_data)
pred_nb <- predict(modelo_nb, test_data)
})
acc_nb <- confusionMatrix(pred_nb, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Naive Bayes", acc_nb, tiempo_nb)
)
tiempo_lr <- system.time({
modelo_lr <- multinom(price_category ~ ., data = train_data, trace = FALSE)
pred_lr <- predict(modelo_lr, test_data)
})
acc_lr <- confusionMatrix(pred_lr, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Regresión Logística", acc_lr, tiempo_lr)
)
preproc_knn <- preProcess(
train_data[, predictores],
method = c("center", "scale")
)
train_scaled <- predict(
preproc_knn,
train_data[, predictores]
)
test_scaled <- predict(
preproc_knn,
test_data[, predictores]
)
tiempo_knn <- system.time({
pred_knn <- knn(
train = train_scaled,
test = test_scaled,
cl = train_data$price_category,
k = 15
)
})
acc_knn <- confusionMatrix(pred_knn, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("KNN", acc_knn, tiempo_knn)
)
tiempo_tree <- system.time({
modelo_tree <- rpart(price_category ~ ., data = train_data)
pred_tree <- predict(modelo_tree, test_data, type = "class")
})
acc_tree <- confusionMatrix(pred_tree, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Árbol de Decisión", acc_tree, tiempo_tree)
)
tiempo_rf <- system.time({
modelo_rf <- randomForest(
price_category ~ .,
data = train_data,
ntree = 50
)
pred_rf <- predict(modelo_rf, test_data)
})
acc_rf <- confusionMatrix(pred_rf, test_data$price_category)$overall["Accuracy"]
resultados_clasificacion <- rbind(
resultados_clasificacion,
agregar_resultado("Random Forest", acc_rf, tiempo_rf)
)
tiempo_rna <- system.time({
modelo_rna <- neuralnet(
formula_nn,
data = train_nn,
hidden = 3,
act.fct = "logistic",
linear.output = FALSE,
stepmax = 1e5
)
})
comparacion_clasificacion <- data.frame(
Modelo = c(
"Naive Bayes",
"SVM RBF",
"Regresión Logística",
"KNN",
"Árbol de Decisión",
"Random Forest",
"RNA Clasificación Tuneada"
),
Accuracy = c(
0.5886,
0.6150,
0.6024,
0.6661,
0.6896,
0.8593,
round(acc_tuned, 4)
),
Tiempo_seg = c(
0.055,
NA,
0.576,
NA,
0.517,
0.523,
NA
)
)
knitr::kable(
comparacion_clasificacion,
caption = "Comparación del mejor modelo RNA con modelos de clasificación anteriores"
)
ggplot(
comparacion_clasificacion,
aes(x = reorder(Modelo, Accuracy), y = Accuracy)
) +
geom_bar(stat = "identity", fill = "steelblue") +
coord_flip() +
theme_minimal() +
labs(
title = "Comparación de accuracy entre modelos de clasificación",
x = "Modelo",
y = "Accuracy"
)
